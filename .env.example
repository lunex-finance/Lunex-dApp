# ── Supabase (public anon keys) ──────────────────────────────────────────────
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# ── Circle user-controlled wallet (email/PIN) ────────────────────────────────
# App ID is public. The entity secret + API key live ONLY on the backend that
# serves /api/uc/* (VITE_API_URL). Never put them in the frontend.
VITE_CIRCLE_UC_APP_ID=
VITE_API_URL=

# ── Circle Modular Wallet (passkey, gasless on Arc) ──────────────────────────
# From console.circle.com → Modular Wallets. Passkey login auto-hides until both
# CLIENT_KEY and CLIENT_URL are set.
VITE_CIRCLE_CLIENT_KEY=
VITE_CIRCLE_CLIENT_URL=
VITE_CIRCLE_CHAIN_PATH=arcTestnet

# ── WalletConnect (RainbowKit) ───────────────────────────────────────────────
# Public, non-secret project id from cloud.reown.com (WalletConnect). Used by the
# Gateway/bridge to connect a multi-chain EOA (injected or mobile QR). A working
# id is bundled as a fallback; override per environment here.
VITE_WALLETCONNECT_PROJECT_ID=
